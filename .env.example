# Copy this file to .env for local testing with `vercel dev` (never commit the real .env).
# In production, set GROQ_API_KEY as an Environment Variable in the Vercel dashboard instead --
# Vercel does not read .env files from your deployed project.

# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: once your Hostinger domain is live, lock the API down to it instead of "*".
# Example: ALLOWED_ORIGIN=https://harjeetpannu.com
ALLOWED_ORIGIN=*
